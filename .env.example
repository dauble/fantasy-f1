# Anthropic API Key for AI Predictions
# Get your key at: https://console.anthropic.com/
# Required for the AI-powered Predictions feature
# Keep this secret - never commit the actual .env file!
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── News Integration (optional) ────────────────────────────────────────────────
# Enable/disable individual news sources (defaults to true)
NEWS_PLANETF1_ENABLED=true
NEWS_MOTORSPORT_ENABLED=true
NEWS_REDDIT_ENABLED=true

# Number of articles to pull from each source (default: 10)
NEWS_MAX_ARTICLES_PER_SOURCE=10

# How long to cache news results in minutes (default: 30)
NEWS_CACHE_TTL_MINUTES=30